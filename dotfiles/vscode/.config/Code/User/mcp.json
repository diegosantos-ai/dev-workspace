{
	"inputs": [
		{
			"id": "chroma_client_type",
			"type": "promptString",
			"description": "Client type: ephemeral (default), persistent, cloud, or http.",
			"password": false
		},
		{
			"id": "chroma_dotenv_path",
			"type": "promptString",
			"description": "Optional path to .env (defaults to ./.chroma_env).",
			"password": false
		},
		{
			"id": "chroma_data_dir",
			"type": "promptString",
			"description": "Data directory for persistent client.",
			"password": false
		},
		{
			"id": "chroma_tenant",
			"type": "promptString",
			"description": "Chroma Cloud tenant ID.",
			"password": false
		},
		{
			"id": "chroma_database",
			"type": "promptString",
			"description": "Chroma Cloud database name.",
			"password": false
		},
		{
			"id": "chroma_api_key",
			"type": "promptString",
			"description": "Chroma Cloud API key.",
			"password": true
		},
		{
			"id": "chroma_host",
			"type": "promptString",
			"description": "Self-hosted Chroma host.",
			"password": false
		},
		{
			"id": "chroma_port",
			"type": "promptString",
			"description": "Self-hosted Chroma port.",
			"password": false
		},
		{
			"id": "chroma_custom_auth",
			"type": "promptString",
			"description": "Custom auth credentials for self-hosted Chroma.",
			"password": true
		},
		{
			"id": "chroma_ssl",
			"type": "promptString",
			"description": "Use SSL (true/false) for self-hosted HTTP.",
			"password": false
		},
		{
			"id": "NETDATA_CLOUD_API_TOKEN",
			"type": "promptString",
			"description": "Netdata Cloud API token (create at app.netdata.cloud > User Settings > API Tokens with scope:mcp)",
			"password": true
		},
		{
			"id": "CONTEXT7_API_KEY",
			"type": "promptString",
			"description": "API key for authentication",
			"password": true
		},
		{
			"id": "e",
			"type": "promptString",
			"description": "Set an environment variable in the runtime",
			"password": false
		},
		{
			"id": "e",
			"type": "promptString",
			"description": "Set an environment variable in the runtime",
			"password": false
		},
		{
			"id": "e",
			"type": "promptString",
			"description": "Set an environment variable in the runtime",
			"password": false
		},
		{
			"id": "TFE_ADDRESS",
			"type": "promptString",
			"description": "HCP Terraform or Terraform Enterprise base URL.",
			"password": false,
			"default": "https://app.terraform.io"
		},
		{
			"id": "TFE_TOKEN",
			"type": "promptString",
			"description": "HCP Terraform or Terraform Enterprise API token used to authenticate requests.",
			"password": true
		},
		{
			"id": "ENABLE_TF_OPERATIONS",
			"type": "pickString",
			"description": "Set to true to enable tools that execute Terraform operations requiring explicit approval.",
			"password": false,
			"default": "false",
			"options": [
				"true",
				"false"
			]
		}
	],
	"servers": {
		"io.github.github/github-mcp-server": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/",
			"gallery": "https://api.mcp.github.com",
			"version": "0.31.0"
		},
		"dev-workspace/devops-mcp-server": {
			"type": "stdio",
			"command": "bash",
			"args": [
				"-lc",
				"set -euo pipefail; if [ -f \"$HOME/.agents-env\" ]; then set -a; . \"$HOME/.agents-env\"; set +a; fi; ROOT=\"${DEV_WORKSPACE_ROOT:-}\"; if [ -z \"$ROOT\" ] && [ -n \"${MCP_SKILLS_PATH:-}\" ] && [ -d \"$MCP_SKILLS_PATH\" ]; then ROOT=\"$(cd \"$MCP_SKILLS_PATH/../..\" && pwd)\"; fi; if [ -z \"$ROOT\" ] && [ -x \"$HOME/labs/dev-workspace/gestao-centralizada-agents/scripts/start-skills-mcp.sh\" ]; then ROOT=\"$HOME/labs/dev-workspace\"; fi; if [ -z \"$ROOT\" ] && [ -x \"$HOME/workspace/platform/dev-workspace/gestao-centralizada-agents/scripts/start-skills-mcp.sh\" ]; then ROOT=\"$HOME/workspace/platform/dev-workspace\"; fi; if [ -z \"$ROOT\" ]; then ROOT=\"$(find \"$HOME\" -maxdepth 5 -path '*/dev-workspace/gestao-centralizada-agents/scripts/start-skills-mcp.sh' -print -quit | sed 's#/gestao-centralizada-agents/scripts/start-skills-mcp.sh##')\"; fi; if [ -z \"$ROOT\" ]; then echo 'Nao foi possivel localizar o clone do dev-workspace.' >&2; exit 1; fi; export DEV_WORKSPACE_ROOT=\"$ROOT\"; exec \"$ROOT/gestao-centralizada-agents/scripts/start-skills-mcp.sh\""
			]
		},
		"chroma-core/chroma-mcp": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"chroma-mcp@v0.2.6"
			],
			"env": {
				"CHROMA_CLIENT_TYPE": "ephemeral",
				"CHROMA_DOTENV_PATH": "./.chroma_env",
				"CHROMA_DATA_DIR": "./chroma_data",
				"CHROMA_TENANT": "local-tenant",
				"CHROMA_DATABASE": "local-db",
				"CHROMA_API_KEY": "preencha_sua_api_key_aqui",
				"CHROMA_HOST": "localhost",
				"CHROMA_PORT": "8000",
				"CHROMA_CUSTOM_AUTH_CREDENTIALS": "",
				"CHROMA_SSL": "false"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		},
		"makenotion/notion-mcp-server": {
			"type": "http",
			"url": "https://mcp.notion.com/sse",
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"io.github.hashicorp/terraform-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"TFE_ADDRESS=https://app.terraform.io",
				"-e",
				"ENABLE_TF_OPERATIONS=false",
				"hashicorp/terraform-mcp-server:0.4.0"
			],
			"env": {
				"TFE_ADDRESS": "https://app.terraform.io",
				"ENABLE_TF_OPERATIONS": "false"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.4.0"
		},
		"io.github.vercel/next-devtools-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"next-devtools-mcp@0.3.6"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.3.6"
		}
	}
}
