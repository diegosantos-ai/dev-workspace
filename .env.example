# ==============================================================================
# TEMPLATE DE VARIÁVEIS DE AMBIENTE - DEVOPS WORKSPACE
# Copie este arquivo para ~/.agents-env (usado pelo setup-agents)
# ou use-o como referencia para secrets de infra (Terraform).
# ==============================================================================

# --- LLM APIs (Agentes IA) ---
OPENAI_API_KEY="<INSIRA_SUA_OPENAI_API_KEY_AQUI>"
ANTHROPIC_API_KEY="<INSIRA_SUA_ANTHROPIC_API_KEY_AQUI>"

# --- Observabilidade ---
LANGFUSE_PUBLIC_KEY="<INSIRA_SUA_LANGFUSE_PUBLIC_KEY_AQUI>"
LANGFUSE_SECRET_KEY="<INSIRA_SUA_LANGFUSE_SECRET_KEY_AQUI>"
LANGFUSE_HOST="http://localhost:3000"

# --- Infraestrutura Core ---
# As senhas de banco na infra-core/docker-compose.yml sao padronizadas por ambiente.
# Evite alterar a menos que modifique o compose local.
POSTGRES_PASSWORD="<INSIRA_SUA_SENHA_DO_POSTGRES_AQUI>"
REDIS_PASSWORD="<INSIRA_SUA_SENHA_DO_REDIS_AQUI>"

# --- Paths (Resolvidos dinamicamente pelo setup) ---
# MCP_SKILLS_PATH=~/labs/dev-workspace/gestao-centralizada-agents/skills-mcp

# --- Credenciais Locais (Ignorar no Git) ---
# Senha do usuario local para automacoes de SUDO (ex: snap, apt updates)
LOCAL_SUDO_PASS="<INSIRA_SUA_SENHA_SUDO_AQUI>"
